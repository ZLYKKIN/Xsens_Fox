# Build output
/build/
/out/
/cmake-build-*/
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
*_autogen/
Makefile
build.ninja
.ninja_deps
.ninja_log

# IDE
/.idea/
/.vs/
/.vscode/
*.user
*.sln
*.suo
*.vcxproj*
*.csproj*

# Compiled objects / executables
*.obj
*.o
*.exe
*.lib
*.exp
*.pdb
*.ilk
*.tlog
*.idb

# Logs and temporary
*.log
*.tmp
*.bak
*.orig

# Runtime log directory — folder itself is tracked so you can commit
# captured logs for bug reports, but ad-hoc *.log files outside of it
# are still ignored via the *.log glob above.

# Internal session/working notes (kept locally, not for public repo)
bugfix.txt
dedup_session.txt
k-pose.txt
aqtinstall.log
build_log.txt

# Blender autosave / backups
*.blend1
*.blend2

# OS junk
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store

# Claude / agent state
/.claude/

# UE plugin build artefacts (binaries / intermediate are regenerated by UBT).
# Glob covers both the legacy layout (Plugins/XsensLivc/...) and the new
# variant layout (Plugins/<variant>/XsensLivc/...).
Plugins/**/XsensLivc/Binaries/
Plugins/**/XsensLivc/Intermediate/
Plugins/**/XsensLivc/Saved/
Plugins/**/XsensLivc/DerivedDataCache/

# Installer / packaging output
/dist/
/installer/Output/

# Hardware-driver redistributables shipped with the installer.
# These are signed third-party installers (Silicon Labs, D-Link, Apple,
# Allied Vision); the *.exe / *.msi rules above would otherwise hide
# them from git.
!installer/drivers/*.exe
!installer/drivers/*.msi

# ONNX Runtime import libs from dll/ — required for Windows linking;
# the *.lib rule above would otherwise hide them from git/CI.
!dll/onnxruntime.lib
!dll/onnxruntime_providers_shared.lib

# Standalone Xsens MVN setup is kept locally as a driver-source mine
# but is 450 MB and proprietary — never commit it.
/Plugins/xsens_mvn_*_setup.exe
tests/python/__pycache__/

# Python bytecode (e.g. from running tools/diff_streams.py)
__pycache__/
*.pyc

# Git bundle deliverables — transient artefacts, not source
*.bundle
