# Default to text with LF normalization in the repo.
* text=auto eol=lf

# Force Windows line endings for Windows-only scripts.
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

# Treat known binary blobs as binary so Git doesn't try diff/normalization.
*.dll       binary
*.exe       binary
*.lib       binary
*.png       binary
*.jpg       binary
*.jpeg      binary
*.blend     binary
*.zip       binary
*.qrc       text
